# BEpusdt 支付环境变量配置
# 复制此文件为 .env 并根据你的环境修改

# === 必填 ===

# BEpusdt API 对接令牌（从 BEpusdt 后台获取）
BEpusdtAPIToken=5AED65D847BA012E38799BCE659FC345

# 你的 USDT TRC20 钱包地址（指定地址模式）
BEpusdtWalletAddress=TZGm3kFjQpEimu6i632M77KpiMip3J9gws

# === 可选（有默认值）===

# BEpusdt 服务地址
BEpusdtAPIURL=https://bepusdt.ai-key.top

# 是否启用
BEpusdtEnabled=true

# 交易类型
BEpusdtTradeType=usdt.trc20

# 法币
BEpusdtFiat=CNY

# 最小充值金额（法币单位）
BEpusdtMinTopUp=10

# 汇率（1 USDT = X 法币）
BEpusdtExchangeRate=7.3
